<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="https://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>ExpenseTracker</display-name>
  
  <filter>
  <filter-name>authenticationFilter</filter-name>
  <filter-class>controller.AuthenticationFilter</filter-class>
  </filter>
  
  <filter-mapping>
  <filter-name>authenticationFilter</filter-name>
  <url-pattern>/auth/*</url-pattern>
  
  </filter-mapping>
  
  <servlet>
  <servlet-name>viewMonthly</servlet-name>
  <servlet-class>controller.ViewMonthly</servlet-class>
  </servlet>
  
  <servlet-mapping>
    <servlet-name>viewMonthly</servlet-name>
    <url-pattern>/auth/viewMonthly</url-pattern>
  </servlet-mapping>
  
    <servlet>
  <servlet-name>viewExpense</servlet-name>
  <servlet-class>controller.ViewExpense</servlet-class>
  </servlet>
  
  <servlet-mapping>
    <servlet-name>viewExpense</servlet-name>
    <url-pattern>/auth/viewExpense</url-pattern>
  </servlet-mapping>
  
  
  <servlet>
  <servlet-name>signup</servlet-name>
  <servlet-class>controller.SignUp</servlet-class>
  </servlet>
  
  <servlet-mapping>
   <servlet-name>signup</servlet-name>
   <url-pattern>/signup</url-pattern>
  </servlet-mapping>
  
  <servlet>
  <servlet-name>logout</servlet-name>
  <servlet-class>controller.Logout</servlet-class>
  </servlet>
  
  <servlet-mapping>
  <servlet-name>logout</servlet-name>
  <url-pattern>/logout</url-pattern>
  </servlet-mapping>
  
  <servlet>
  <servlet-name>monthlyExpense</servlet-name>
  <servlet-class>controller.MonthlyExpense</servlet-class>
  </servlet>
  
  <servlet-mapping>
  <servlet-name>monthlyExpense</servlet-name>
  <url-pattern>/auth/monthlyExpense</url-pattern>
  </servlet-mapping>
  
    <servlet>
  <servlet-name>generate</servlet-name>
  <servlet-class>controller.Generate</servlet-class>
  </servlet>
  
  <servlet-mapping>
   <servlet-name>generate</servlet-name>
   <url-pattern>/auth/generate</url-pattern>
   
  </servlet-mapping>
  
  
    <servlet>
  <servlet-name>login</servlet-name>
  <servlet-class>controller.Login</servlet-class>
  </servlet>
  
  <servlet-mapping>
   <servlet-name>login</servlet-name>
   <url-pattern>/login</url-pattern>
   
  </servlet-mapping>
  
    <servlet>
  <servlet-name>insertExpense</servlet-name>
  <servlet-class>controller.InsertExpense</servlet-class>
  </servlet>
  
  <servlet-mapping>
   <servlet-name>insertExpense</servlet-name>
   <url-pattern>/auth/insertExpense</url-pattern>
   
  </servlet-mapping>
</web-app>